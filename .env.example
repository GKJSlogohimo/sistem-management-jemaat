# Neon PostgreSQL
# Runtime aplikasi: gunakan pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?sslmode=require"

# Prisma migrate: gunakan direct connection string.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Gmail SMTP
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM="Sistem Manajemen Jemaat <email@gmail.com>"

# Ably, hanya server-side
ABLY_API_KEY=""